{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://din18599-ifc.de/schema/v2.2/complete",
  "title": "DIN 18599 IFC Sidecar v2.2 - Complete Schema",
  "description": "Schema mit Bauteiltyp-basierter Struktur (walls, roofs, floors) statt opak/transparent",
  "version": "2.2.0",
  "type": "object",
  "required": ["schema_info", "meta", "input"],
  
  "properties": {
    "schema_info": {
      "type": "object",
      "description": "Schema-Metadaten",
      "required": ["url", "version"],
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "const": "https://din18599-ifc.de/schema/v2.2/complete"
        },
        "version": {
          "type": "string",
          "pattern": "^2\\.2\\.\\d+$",
          "description": "Schema-Version (Semantic Versioning)"
        }
      }
    },
    
    "meta": {
      "type": "object",
      "description": "Projekt-Metadaten und Versionierung",
      "required": ["project_name", "created"],
      "properties": {
        "project_name": {"type": "string"},
        "project_id": {"type": "string"},
        "created": {"type": "string", "format": "date-time"},
        "last_modified": {"type": "string", "format": "date-time"},
        "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
        "version_history": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["version", "date", "changes"],
            "properties": {
              "version": {"type": "string"},
              "date": {"type": "string", "format": "date-time"},
              "changes": {"type": "string"},
              "author": {"type": "string"}
            }
          }
        },
        "ifc_file_ref": {"type": "string"},
        "ifc_schema": {
          "type": "string",
          "enum": ["IFC2X3", "IFC4", "IFC4X3"],
          "description": "IFC-Schema-Version der Quelldatei"
        },
        "lod": {
          "type": "string",
          "enum": ["100", "200", "300", "400", "500"]
        }
      }
    },
    
    "input": {
      "type": "object",
      "description": "Eingabedaten (Definition) - Source of Truth",
      "required": ["building"],
      "properties": {
        "building": {"$ref": "#/definitions/building"},
        "envelope": {"$ref": "#/definitions/envelope"},
        "systems": {"$ref": "#/definitions/systems"},
        "electricity": {"$ref": "#/definitions/electricity"},
        "automation": {"$ref": "#/definitions/automation"},
        "primary_energy": {"$ref": "#/definitions/primary_energy_factors"},
        "climate": {"$ref": "#/definitions/climate"}
      }
    },
    
    "scenarios": {
      "type": "array",
      "items": {"$ref": "#/definitions/scenario"}
    },
    
    "output": {
      "type": "object",
      "properties": {
        "base": {"$ref": "#/definitions/output_snapshot"}
      },
      "patternProperties": {
        "^scenario_": {"$ref": "#/definitions/output_snapshot"}
      }
    }
  },
  
  "definitions": {
    "building": {
      "type": "object",
      "required": ["address", "construction_year", "heated_area"],
      "properties": {
        "address": {
          "type": "object",
          "required": ["zip", "city"],
          "properties": {
            "street": {"type": "string"},
            "zip": {"type": "string"},
            "city": {"type": "string"},
            "country": {"type": "string", "default": "DE"}
          }
        },
        "construction_year": {"type": "integer", "minimum": 1800, "maximum": 2100},
        "renovation_year": {"type": "integer", "minimum": 1800, "maximum": 2100},
        "type": {"type": "string", "enum": ["residential", "non_residential", "mixed"]},
        "subtype": {"type": "string"},
        "heated_area": {"type": "number", "minimum": 0},
        "gross_floor_area": {"type": "number", "minimum": 0},
        "heated_volume": {"type": "number", "minimum": 0},
        "av_ratio": {"type": "number", "minimum": 0},
        "storeys": {
          "type": "array",
          "description": "A4: Geschosse mit Elevation",
          "items": {"$ref": "#/definitions/storey"}
        },
        "zones": {
          "type": "array",
          "items": {"$ref": "#/definitions/zone"}
        }
      }
    },
    
    "storey": {
      "type": "object",
      "description": "A4: Geschoss-Metadaten aus IFC",
      "required": ["id", "name"],
      "properties": {
        "id": {"type": "string", "description": "IFC GUID"},
        "name": {"type": "string"},
        "elevation": {
          "type": "number",
          "description": "Geschosshöhe [m] über Projektbasis"
        }
      }
    },
    
    "zone": {
      "type": "object",
      "required": ["id", "usage_profile_ref", "area", "volume", "height"],
      "properties": {
        "id": {"type": "string"},
        "ifc_guid": {"type": "string", "description": "A4: IFC GUID des IfcSpace"},
        "name": {"type": "string"},
        "usage_profile_ref": {"type": "string"},
        "area": {"type": "number", "minimum": 0, "description": "Zonenfläche [m²]"},
        "volume": {"type": "number", "minimum": 0, "description": "A3: Zonenvolumen [m³]"},
        "height": {"type": "number", "minimum": 0, "description": "A3: Raumhöhe [m]"},
        "storey_ref": {
          "type": "string",
          "description": "A3: Referenz zu Geschoss (storey.id)"
        },
        "setpoint_heating_c": {"type": "number"},
        "setpoint_cooling_c": {"type": "number"},
        "air_change_rate_h": {"type": "number", "minimum": 0},
        "conditioned": {"type": "boolean"}
      }
    },
    
    "envelope": {
      "type": "object",
      "description": "A1: Gebäudehülle nach Bauteiltyp strukturiert",
      "properties": {
        "walls": {
          "type": "array",
          "description": "A1: Wände (inkl. AW/IW, Neigung ~90°)",
          "items": {"$ref": "#/definitions/opaque_element"}
        },
        "roofs": {
          "type": "array",
          "description": "A1: Dächer (Neigung 0-60°)",
          "items": {"$ref": "#/definitions/opaque_element"}
        },
        "floors": {
          "type": "array",
          "description": "A1: Böden/Decken (Neigung ~0°)",
          "items": {"$ref": "#/definitions/opaque_element"}
        },
        "windows": {
          "type": "array",
          "description": "A1: Fenster",
          "items": {"$ref": "#/definitions/transparent_element"}
        },
        "doors": {
          "type": "array",
          "description": "A1: Türen",
          "items": {"$ref": "#/definitions/transparent_element"}
        },
        "thermal_bridges": {
          "type": "object",
          "properties": {
            "method": {"type": "string", "enum": ["NONE", "SIMPLIFIED", "DETAILED"]},
            "delta_u_wb": {"type": "number"},
            "linear_bridges": {
              "type": "array",
              "items": {"$ref": "#/definitions/linear_thermal_bridge"}
            }
          }
        }
      }
    },
    
    "opaque_element": {
      "type": "object",
      "required": ["id", "area"],
      "properties": {
        "id": {"type": "string"},
        "ifc_guid": {"type": "string", "description": "A4: IFC GUID"},
        "ifc_type": {
          "type": "string",
          "description": "A4: IFC-Typ (IfcWall, IfcSlab, IfcRoof)"
        },
        "predefined_type": {
          "type": "string",
          "description": "A4: IFC PredefinedType (ROOF, FLOOR, BASESLAB)"
        },
        "name": {"type": "string", "description": "A4: IFC Name"},
        "construction_ref": {"type": "string"},
        "u_value": {"type": "number", "minimum": 0, "description": "U-Wert [W/(m²K)]"},
        "area": {"type": "number", "minimum": 0, "description": "Fläche [m²]"},
        "orientation": {
          "type": "number",
          "minimum": 0,
          "maximum": 360,
          "description": "Orientierung [°] (0=N, 90=O, 180=S, 270=W)"
        },
        "inclination": {
          "type": "number",
          "minimum": 0,
          "maximum": 90,
          "description": "Neigung [°] (0=horizontal, 90=vertikal)"
        },
        "boundary_condition": {
          "type": "string",
          "enum": ["exterior", "ground", "unheated", "adjacent"],
          "description": "A2: Randbedingung für Fx-Faktoren (statt opak/transparent)"
        },
        "din_code": {
          "type": "string",
          "enum": ["WA", "WI", "DA", "DE", "DU", "BE", "BO", "BU"],
          "description": "B1: DIN 18599 Bauteilcode (Beiblatt 3 Tabelle 77-85)"
        },
        "fx_factor": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "B2: Temperatur-Korrekturfaktor Fx (Beiblatt 3 Tabelle 77-92)"
        },
        "storey_ref": {
          "type": "string",
          "description": "A4: Referenz zu Geschoss"
        }
      }
    },
    
    "transparent_element": {
      "type": "object",
      "required": ["id", "area"],
      "properties": {
        "id": {"type": "string"},
        "ifc_guid": {"type": "string", "description": "A4: IFC GUID"},
        "ifc_type": {"type": "string", "description": "A4: IfcWindow, IfcDoor"},
        "name": {"type": "string"},
        "construction_ref": {"type": "string"},
        "u_value": {"type": "number", "minimum": 0},
        "g_value": {"type": "number", "minimum": 0, "maximum": 1},
        "area": {"type": "number", "minimum": 0},
        "orientation": {"type": "number", "minimum": 0, "maximum": 360},
        "inclination": {
          "type": "number",
          "minimum": 0,
          "maximum": 90,
          "description": "B4: Neigung [°] für FA/FD/FL-Unterscheidung (Beiblatt 3)"
        },
        "is_glazed": {
          "type": "boolean",
          "description": "Verglast? (für GEG-Kategorisierung)"
        },
        "tau_value": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "B3: Transmissionsgrad für Tageslicht τ [-] (Beiblatt 3 Tabelle 86-92)"
        },
        "g_value_perpendicular": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "B3: Gesamtenergiedurchlassgrad senkrecht g⊥ [-]"
        },
        "g_value_summer": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "B3: g-Wert mit Sonnenschutz Sommer (Beiblatt 3)"
        },
        "g_value_winter": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "B3: g-Wert mit Sonnenschutz Winter (Beiblatt 3)"
        },
        "shading_factor_f_sh": {"type": "number", "minimum": 0, "maximum": 1},
        "boundary_condition": {
          "type": "string",
          "enum": ["exterior", "ground", "unheated", "adjacent"],
          "description": "A2: Randbedingung"
        },
        "din_code": {
          "type": "string",
          "enum": ["FA", "FD", "FL", "TA", "TD"],
          "description": "B1: DIN 18599 Bauteilcode (Beiblatt 3 Tabelle 86-92)"
        },
        "fx_factor": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "B2: Temperatur-Korrekturfaktor Fx"
        },
        "parent_wall_guid": {
          "type": "string",
          "description": "A4: GUID der zugehörigen Wand"
        },
        "storey_ref": {"type": "string"}
      }
    },
    
    "linear_thermal_bridge": {
      "type": "object",
      "properties": {
        "id": {"type": "string"},
        "type": {"type": "string"},
        "psi_value": {"type": "number"},
        "length": {"type": "number", "minimum": 0}
      }
    },
    
    "systems": {
      "type": "object",
      "properties": {
        "heating": {"$ref": "#/definitions/heating_system"},
        "ventilation": {"$ref": "#/definitions/ventilation_system"},
        "cooling": {"$ref": "#/definitions/cooling_system"},
        "lighting": {"$ref": "#/definitions/lighting_system"},
        "dhw": {"$ref": "#/definitions/dhw_system"}
      }
    },
    
    "heating_system": {
      "type": "object",
      "properties": {
        "generation": {
          "type": "object",
          "properties": {
            "type": {"type": "string"},
            "installation_year": {"type": "integer"},
            "nominal_power_kw": {"type": "number", "minimum": 0},
            "efficiency": {"type": "number", "minimum": 0, "maximum": 1}
          }
        },
        "distribution": {
          "type": "object",
          "properties": {
            "type": {"type": "string"},
            "insulation_standard": {"type": "string"}
          }
        },
        "emission": {"type": "object", "properties": {"type": {"type": "string"}}},
        "control": {
          "type": "object",
          "properties": {
            "type": {"type": "string"},
            "efficiency_factor": {"type": "number", "minimum": 0, "maximum": 1}
          }
        }
      }
    },
    
    "ventilation_system": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["natural", "mechanical_exhaust", "mechanical_supply_exhaust", "hybrid", "demand_controlled"]
        },
        "n50_value": {"type": "number", "minimum": 0},
        "heat_recovery": {"type": "boolean"},
        "heat_recovery_efficiency": {"type": "number", "minimum": 0, "maximum": 1},
        "air_flow_rate_m3h": {"type": "number", "minimum": 0}
      }
    },
    
    "cooling_system": {
      "type": "object",
      "properties": {
        "installed": {"type": "boolean"},
        "type": {"type": "string"},
        "nominal_power_kw": {"type": "number", "minimum": 0},
        "eer": {"type": "number", "minimum": 0}
      }
    },
    
    "lighting_system": {
      "type": "object",
      "properties": {
        "applicable": {"type": "boolean"},
        "installed_power_w_m2": {"type": "number", "minimum": 0},
        "control_type": {"type": "string"}
      }
    },
    
    "dhw_system": {
      "type": "object",
      "properties": {
        "type": {"type": "string"},
        "storage_volume_l": {"type": "number", "minimum": 0},
        "circulation": {"type": "boolean"}
      }
    },
    
    "electricity": {
      "type": "object",
      "properties": {
        "pv": {
          "type": "object",
          "properties": {
            "installed": {"type": "boolean"},
            "peak_power_kwp": {"type": "number", "minimum": 0},
            "area_m2": {"type": "number", "minimum": 0},
            "orientation": {"type": "number", "minimum": 0, "maximum": 360},
            "inclination": {"type": "number", "minimum": 0, "maximum": 90}
          }
        }
      }
    },
    
    "automation": {
      "type": "object",
      "properties": {
        "installed": {"type": "boolean"},
        "bacs_class": {"type": "string", "enum": ["A", "B", "C", "D"]},
        "efficiency_factor_heating": {"type": "number", "minimum": 0, "maximum": 1},
        "efficiency_factor_cooling": {"type": "number", "minimum": 0, "maximum": 1},
        "efficiency_factor_ventilation": {"type": "number", "minimum": 0, "maximum": 1},
        "efficiency_factor_lighting": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    
    "primary_energy_factors": {
      "type": "object",
      "required": ["source"],
      "properties": {
        "source": {"type": "string", "enum": ["GEG_2024", "BEG_2024", "DIN_18599", "CUSTOM"]},
        "reference_year": {"type": "integer"},
        "factors": {
          "type": "object",
          "properties": {
            "electricity": {"type": "number", "minimum": 0},
            "natural_gas": {"type": "number", "minimum": 0},
            "oil": {"type": "number", "minimum": 0},
            "district_heating": {"type": "number", "minimum": 0},
            "wood_pellets": {"type": "number", "minimum": 0}
          }
        },
        "co2_factors": {
          "type": "object",
          "properties": {
            "electricity": {"type": "number", "minimum": 0},
            "natural_gas": {"type": "number", "minimum": 0},
            "oil": {"type": "number", "minimum": 0}
          }
        }
      }
    },
    
    "climate": {
      "type": "object",
      "properties": {
        "try_region": {"type": "string"},
        "heating_degree_days": {"type": "number", "minimum": 0}
      }
    },
    
    "scenario": {
      "type": "object",
      "required": ["id", "name", "delta"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9_]+$"},
        "name": {"type": "string"},
        "description": {"type": "string"},
        "priority": {"type": "integer", "minimum": 1},
        "timeline": {"type": "integer"},
        "delta": {
          "type": "object",
          "properties": {
            "elements": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id"],
                "properties": {
                  "id": {"type": "string"},
                  "construction_ref": {"type": "string"},
                  "u_value": {"type": "number"}
                }
              }
            },
            "systems": {"type": "object"}
          }
        }
      }
    },
    
    "output_snapshot": {
      "type": "object",
      "properties": {
        "meta": {
          "type": "object",
          "required": ["calculation_date", "input_hash"],
          "properties": {
            "calculated_by": {"type": "string"},
            "calculation_date": {"type": "string", "format": "date-time"},
            "software": {"type": "string"},
            "software_version": {"type": "string"},
            "input_hash": {"type": "string"},
            "valid": {"type": "boolean"}
          }
        },
        "useful_energy": {"type": "object", "properties": {"per_zone": {"type": "array"}, "total": {"type": "object"}}},
        "final_energy": {
          "type": "object",
          "properties": {
            "reference_system": {"type": "string", "enum": ["gross_calorific_value", "net_calorific_value"]},
            "by_carrier": {"type": "object"},
            "by_zone_and_application": {"type": "object"}
          }
        },
        "primary_energy": {
          "type": "object",
          "properties": {
            "reference_system": {"type": "string", "enum": ["non_renewable", "renewable", "total"]},
            "by_carrier": {"type": "object"},
            "by_zone_and_application": {"type": "object"}
          }
        },
        "co2_emissions": {"type": "object", "properties": {"by_carrier": {"type": "object"}, "by_zone_and_application": {"type": "object"}}},
        "specific_values": {
          "type": "object",
          "properties": {
            "reference_area": {"type": "number"},
            "useful_energy": {"type": "object"},
            "final_energy": {"type": "object"},
            "primary_energy": {"type": "object"},
            "co2_emissions": {"type": "object"}
          }
        },
        "savings": {
          "type": "object",
          "properties": {
            "final_energy_percent": {"type": "number"},
            "primary_energy_percent": {"type": "number"},
            "co2_percent": {"type": "number"},
            "cost_annual_euro": {"type": "number"}
          }
        }
      }
    }
  }
}
