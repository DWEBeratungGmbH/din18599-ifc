              "properties": {
                "total": {"type": "number", "description": "[kWh/(m²·a)]"}
              }
            },
            "co2_emissions": {
              "type": "object",
              "properties": {
                "total": {"type": "number", "description": "[kg/(m²·a)]"}
              }
            }
          }
        },
        "savings": {
