                "oil": {"type": "number", "minimum": 0},
                "district_heating": {"type": "number", "minimum": 0},
                "wood_pellets": {"type": "number", "minimum": 0}
              }
            },
            "by_zone_and_application": {
              "type": "object",
              "description": "Nach Zone und Anwendung",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "heating": {"type": "number"},
                  "cooling": {"type": "number"},
                  "dhw": {"type": "number"},
                  "lighting": {"type": "number"},
                  "ventilation": {"type": "number"}
                }
              }
            },
            "total": {"type": "number", "minimum": 0}
          }
        },
        "co2_emissions": {
          "type": "object",
          "description": "CO2-Emissionen [kg/a]",
          "properties": {
            "by_carrier": {
              "type": "object",
              "properties": {
