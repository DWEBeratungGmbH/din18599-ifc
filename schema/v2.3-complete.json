                }
              }
            },
            "systems": {
              "type": "object",
              "description": "Geänderte Anlagentechnik",
              "properties": {
                "heating": {"type": "object"},
                "ventilation": {"type": "object"},
                "dhw": {"type": "object"}
              }
            }
          }
        }
      }
    },
    
