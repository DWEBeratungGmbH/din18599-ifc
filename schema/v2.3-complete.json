        "name": {"type": "string", "description": "z.B. 'Fassadendämmung WDVS 16cm'"},
        "description": {"type": "string"},
        "priority": {"type": "integer", "minimum": 1, "description": "Priorität (1=hoch)"},
        "timeline": {"type": "integer", "description": "Umsetzungsjahr"},
        "delta": {
          "type": "object",
          "description": "Änderungen gegenüber Basis",
          "properties": {
            "elements": {
              "type": "array",
