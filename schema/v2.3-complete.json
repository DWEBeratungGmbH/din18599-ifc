                "natural_gas": {"type": "number", "minimum": 0},
                "oil": {"type": "number", "minimum": 0},
                "district_heating": {"type": "number", "minimum": 0}
              }
            },
            "by_zone_and_application": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "properties": {
                  "heating": {"type": "number"},
                  "cooling": {"type": "number"},
                  "dhw": {"type": "number"},
                  "lighting": {"type": "number"},
                  "ventilation": {"type": "number"}
                }
              }
            },
            "total": {"type": "number", "minimum": 0}
          }
        },
        "specific_values": {
          "type": "object",
          "description": "Spezifische Werte pro m² Bezugsfläche",
          "properties": {
            "reference_area": {"type": "number", "minimum": 0, "description": "Bezugsfläche [m²]"},
            "useful_energy": {
