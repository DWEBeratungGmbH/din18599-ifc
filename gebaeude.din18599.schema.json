{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IFC + DIN 18599 Sidecar",
  "description": "JSON Sidecar für IFC-Dateien zur Abbildung von Energieberatungsdaten nach DIN 18599. Unterteilt in Input (Definition) und Output (Ergebnisse). Unterstützt Varianten-Management (Delta-Modell).",
  "type": "object",
  "oneOf": [
    {
      "description": "Legacy Format: Einzelne Datei ohne Varianten",
      "properties": {
        "schema_info": { "$ref": "#/definitions/schema_info" },
        "meta": { "$ref": "#/definitions/meta" },
        "input": { "$ref": "#/definitions/input" },
        "output": { "$ref": "#/definitions/output" }
      },
      "required": ["schema_info", "meta", "input"],
      "not": { "anyOf": [{ "required": ["base"] }, { "required": ["scenarios"] }] }
    },
    {
      "description": "Varianten-Format: Base + Scenarios (Delta-Modell)",
      "properties": {
        "schema_info": { "$ref": "#/definitions/schema_info" },
        "meta": { "$ref": "#/definitions/meta_variants" },
        "base": {
          "description": "IST-Zustand / Ausgangsvariante",
          "type": "object",
          "properties": {
            "meta": { "$ref": "#/definitions/meta" },
            "input": { "$ref": "#/definitions/input" },
            "output": { "$ref": "#/definitions/output" }
          },
          "required": ["meta", "input"]
        },
        "scenarios": {
          "description": "Sanierungs-/Planungsvarianten als Delta zum Base",
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "description": "Eindeutige Varianten-ID" },
              "name": { "type": "string", "description": "Variantenname (z.B. 'Sanierung WDVS + Fenster')" },
              "description": { "type": "string", "description": "Beschreibung der Maßnahmen" },
              "delta": {
                "description": "Nur geänderte Werte (werden mit Base gemerged)",
                "type": "object",
                "properties": {
                  "meta": { "$ref": "#/definitions/meta_partial" },
                  "elements": { "type": "array", "description": "Geänderte/neue Bauteile" },
                  "windows": { "type": "array", "description": "Geänderte/neue Fenster" },
                  "layer_structures": { "type": "array", "description": "Geänderte/neue Schichtaufbauten" },
                  "materials": { "type": "array", "description": "Geänderte/neue Materialien" },
                  "systems": { "type": "array", "description": "Geänderte/neue Systeme" }
                }
              },
              "output": { "$ref": "#/definitions/output" }
            },
            "required": ["id", "name", "delta"]
          }
        }
      },
      "required": ["schema_info", "meta", "base", "scenarios"]
    }
  ],
  "definitions": {
    "schema_info": {
      "type": "object",
      "properties": {
        "url": { "type": "string", "const": "https://din18599-ifc.de/schema/v1" },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" }
      },
      "required": ["url", "version"]
    },
    "meta": {
      "description": "Metadaten zum Projekt und zur Berechnung",
      "type": "object",
      "properties": {
        "project_id": { "type": "string" },
        "project_name": { "type": "string" },
        "ifc_file_ref": { "type": "string", "description": "Dateiname der zugehörigen IFC-Datei" },
        "ifc_guid_building": { "type": "string", "description": "IfcBuilding GUID" },
        "simplified_geometry": { "type": "boolean", "description": "Enthält vereinfachte 3D-Geometrie im Sidecar" },
        "geometry_mode": { 
          "type": "string", 
          "enum": ["STANDALONE", "SIMPLIFIED", "IFC_LINKED", "HIERARCHICAL", "BREP"],
          "description": "Geometrie-Modus: STANDALONE (keine Geo), SIMPLIFIED (2D/3D im Sidecar), IFC_LINKED (nur IFC), HIERARCHICAL (Parent-Child), BREP (Boundary Representation mit Vertices+Faces)"
        },
        "software_name": { "type": "string" },
        "software_version": { "type": "string" },
        "calculation_date": { "type": "string", "format": "date-time" },
        "norm_version": { "type": "string", "description": "Angewandte Norm, z.B. DIN V 18599:2018-09" },
        "lod": {
          "type": "string",
          "enum": ["100", "200", "300", "400", "500"],
          "description": "Level of Detail (BIM-inspiriert): 100=Konzept, 200=Vorentwurf, 300=Entwurf, 400=Ausführung, 500=As-Built"
        },
        "data_quality": {
          "type": "object",
          "description": "LOD-Level für verschiedene Bereiche (falls abweichend vom Gesamt-LOD)",
          "properties": {
            "geometry": { "type": "string", "enum": ["100", "200", "300", "400", "500"] },
            "envelope": { "type": "string", "enum": ["100", "200", "300", "400", "500"] },
            "systems": { "type": "string", "enum": ["100", "200", "300", "400", "500"] }
          }
        },
        "catalog_references": {
          "type": "array",
          "description": "Verwendete Kataloge (z.B. DE_BMWI2020_BAUTEILE v1.0)",
          "items": { "type": "string" }
        }
      },
      "required": ["ifc_file_ref", "ifc_guid_building"]
    },
    "meta_variants": {
      "description": "Metadaten für Varianten-Datei",
      "type": "object",
      "properties": {
        "project_id": { "type": "string" },
        "project_name": { "type": "string" },
        "variant_set_name": { "type": "string", "description": "Name des Variantensets (z.B. 'iSFP Sanierungsfahrplan')" },
        "created_date": { "type": "string", "format": "date-time" }
      },
      "required": ["project_name", "variant_set_name"]
    },
    "meta_partial": {
      "description": "Partielle Metadaten für Scenario-Delta (nur änderbare Felder)",
      "type": "object",
      "properties": {
        "calculation_date": { "type": "string", "format": "date-time" },
        "lod": { "type": "string", "enum": ["100", "200", "300", "400", "500"] },
        "software_version": { "type": "string" }
      }
    },
    "input": {
      "description": "Eingabedaten für die Berechnung (Source of Truth)",
      "type": "object",
      "properties": {
        "building": {
          "type": "object",
          "description": "Gebäude-Geometrie und Orientierung",
          "properties": {
            "geometry": {
              "type": "object",
              "properties": {
                "origin": {
                  "type": "array",
                  "items": { "type": "number" },
                  "minItems": 3,
                  "maxItems": 3,
                  "description": "Gebäude-Ursprung [x, y, z] in Metern"
                },
                "north_angle": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 360,
                  "description": "Nord-Ausrichtung in Grad (0° = Y-Achse zeigt nach Norden)"
                }
              }
            }
          }
        },
        "climate_location": {
          "type": "object",
          "properties": {
            "postcode": { "type": "string" },
            "city": { "type": "string" },
            "try_region_code": { "type": "integer", "description": "Testreferenzjahr-Region (1-15)" }
          }
        },
        "zones": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "usage_profile": { "type": "string", "description": "Code nach DIN 18599-10, z.B. '17'" },
              "area_an": { "type": "number", "description": "Energiebezugsfläche AN in m²" },
              "height_h": { "type": "number", "description": "Lichte Raumhöhe in m" },
              "volume_v": { "type": "number", "description": "Nettoraumvolumen Vi in m³" },
              "air_change_n50": { "type": "number", "description": "Luftwechselrate 1/h bei 50 Pa" },
              "design_temp_heating": { "type": "number", "description": "Soll-Temperatur Heizen in °C" },
              "design_temp_cooling": { "type": "number", "description": "Soll-Temperatur Kühlen in °C" },
              "lighting_control": {
                "type": "string",
                "enum": ["MANUAL", "PRESENCE", "DAYLIGHT", "FULL_AUTO"]
              },
              "space_guids": {
                "type": "array",
                "items": { "type": "string", "description": "GUIDs der zugeordneten IfcSpace Objekte" }
              },
              "geometry": {
                "type": "object",
                "description": "Vereinfachte 3D-Geometrie (optional)",
                "properties": {
                  "type": { "type": "string", "enum": ["Polygon2D", "Polygon3D"] },
                  "parent_ref": { "type": "string", "description": "Referenz zum Parent (z.B. 'BUILDING')" },
                  "local_origin": {
                    "type": "array",
                    "items": { "type": "number" },
                    "minItems": 3,
                    "maxItems": 3,
                    "description": "Position relativ zum Parent [x, y, z]"
                  },
                  "rotation": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 360,
                    "description": "Rotation um Z-Achse in Grad (relativ zum Parent)"
                  },
                  "coordinates": {
                    "type": "array",
                    "description": "Polygon-Punkte (2D oder 3D)",
                    "items": {
                      "type": "array",
                      "items": { "type": "number" },
                      "minItems": 2,
                      "maxItems": 3
                    }
                  },
                  "floor_level": { "type": "number", "description": "Geschosshöhe in m" },
                  "ceiling_height": { "type": "number", "description": "Raumhöhe in m" }
                }
              },
              "spaces": {
                "type": "array",
                "description": "Räume innerhalb der Zone (optional, für detaillierte Modelle)",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "name": { "type": "string" },
                    "area_an": { "type": "number" },
                    "geometry": {
                      "type": "object",
                      "properties": {
                        "type": { "type": "string", "enum": ["Polygon2D", "Polygon3D"] },
                        "parent_ref": { "type": "string", "description": "Referenz zur Zone" },
                        "local_origin": {
                          "type": "array",
                          "items": { "type": "number" },
                          "minItems": 3,
                          "maxItems": 3
                        },
                        "coordinates": {
                          "type": "array",
                          "items": {
                            "type": "array",
                            "items": { "type": "number" },
                            "minItems": 2,
                            "maxItems": 3
                          }
                        }
                      }
                    }
                  },
                  "required": ["id", "name"]
                }
              }
            },
            "required": ["id", "usage_profile"]
          }
        },
        "elements": {
          "description": "Opake Bauteile (Wände, Decken, Dächer)",
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "description": "Eindeutige Element-ID" },
              "name": { "type": "string", "description": "Bauteilname" },
              "type": {
                "type": "string",
                "enum": ["WALL", "ROOF", "FLOOR", "CEILING", "SLAB"],
                "description": "Bauteiltyp"
              },
              "zone_id": { "type": "string", "description": "Referenz zur Zone" },
              "space_id": { "type": "string", "description": "Referenz zum Raum (optional)" },
              "ifc_guid": { "type": "string", "description": "Referenz zu IfcWall, IfcSlab, etc." },
              "area": { "type": "number", "description": "Bauteilfläche in m²" },
              "boundary_condition": {
                "type": "string",
                "enum": ["EXTERIOR", "GROUND", "UNHEATED", "HEATED", "ADIABATIC", "INTERIOR"]
              },
              "u_value_undisturbed": { "type": "number", "description": "U-Wert im Gefach (ohne Wärmebrücken) W/m²K" },
              "thermal_bridge_delta_u": { "type": "number", "description": "Wärmebrückenzuschlag W/m²K" },
              "thermal_bridge_type": {
                "type": "string",
                "enum": ["DEFAULT", "REDUCED", "DETAILED"]
              },
              "solar_absorption": { "type": "number", "description": "Absorptionsgrad der Oberfläche (0-1)" },
              "orientation": { "type": "number", "description": "DEPRECATED: Absolute Orientierung 0=N, 90=O, 180=S, 270=W" },
              "relative_orientation": { 
                "type": "number", 
                "minimum": 0,
                "maximum": 360,
                "description": "Orientierung relativ zum Gebäude in Grad (0=vorne, 90=rechts, 180=hinten, 270=links)"
              },
              "inclination": { "type": "number", "description": "0=Horizontal, 90=Vertikal" },
              "layer_structure_ref": { "type": "string", "description": "Referenz auf eine Schichtaufbau-ID" },
              "u_value_override": { "type": "number", "description": "Manueller U-Wert überschreibt automatische Berechnung aus layer_structure_ref" },
              "construction_catalog_ref": { "type": "string", "description": "Referenz auf Katalog-Eintrag (z.B. AW_VOLLZIEGEL_BIS20_BMWI)" },
              "geometry": {
                "type": "object",
                "description": "Vereinfachte Geometrie (optional)",
                "properties": {
                  "type": { "type": "string", "enum": ["Line2D", "Rectangle2D", "Polygon2D", "Polygon3D"] },
                  "parent_ref": { "type": "string", "description": "Referenz zum Parent (Space oder Zone)" },
                  "local_origin": {
                    "type": "array",
                    "items": { "type": "number" },
                    "minItems": 3,
                    "maxItems": 3
                  },
                  "start": {
                    "type": "array",
                    "items": { "type": "number" },
                    "minItems": 2,
                    "maxItems": 3,
                    "description": "Startpunkt (für Line2D)"
                  },
                  "end": {
                    "type": "array",
                    "items": { "type": "number" },
                    "minItems": 2,
                    "maxItems": 3,
                    "description": "Endpunkt (für Line2D)"
                  },
                  "height": { "type": "number", "description": "Höhe für Extrusion (Line2D → Wand)" },
                  "coordinates": {
                    "type": "array",
                    "description": "Polygon-Punkte",
                    "items": {
                      "type": "array",
                      "items": { "type": "number" }
                    }
                  }
                }
              }
            },
            "required": ["boundary_condition"]
          }
        },
        "windows": {
          "description": "Transparente Bauteile (Fenster, Türen)",
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "ifc_guid": { "type": "string", "description": "Referenz zu IfcWindow/IfcDoor" },
              "u_value_glass": { "type": "number", "description": "Ug-Wert Verglasung" },
              "u_value_frame": { "type": "number", "description": "Uf-Wert Rahmen" },
              "psi_spacer": { "type": "number", "description": "Psi-Wert Randverbund W/mK" },
              "g_value": { "type": "number", "description": "Gesamtenergiedurchlassgrad (0-1)" },
              "frame_fraction": { "type": "number", "description": "Rahmenanteil 0.0-1.0" },
              "shading_factor_fs": { "type": "number", "description": "Verschattungsfaktor Fs 0.0-1.0 (pauschal)" },
              "horizon_angle": { "type": "number", "description": "Horizontüberhöhungswinkel in Grad" },
              "overhang_angle": { "type": "number", "description": "Überhangwinkel in Grad" }
            },
            "required": ["ifc_guid", "u_value_glass", "u_value_frame", "g_value"]
          }
        },
        "materials": {
          "type": "array",
          "description": "Materialien für Schichtaufbauten",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["STANDARD", "AIR_LAYER"],
                "default": "STANDARD",
                "description": "STANDARD=normales Material, AIR_LAYER=ruhende/belüftete Luftschicht"
              },
              "lambda": { "type": "number", "description": "Wärmeleitfähigkeit W/(m·K) (nur bei STANDARD)" },
              "density": { "type": "number", "description": "Rohdichte kg/m³ (nur bei STANDARD)" },
              "specific_heat": { "type": "number", "description": "Spezifische Wärmekapazität J/(kg·K) (optional)" },
              "vapor_resistance_factor": { "type": "number", "description": "Wasserdampf-Diffusionswiderstandszahl μ (optional)" },
              "air_layer_type": {
                "type": "string",
                "enum": ["STILL", "SLIGHTLY_VENTILATED", "HIGHLY_VENTILATED"],
                "description": "Luftschichttyp nach EN ISO 6946 (nur bei AIR_LAYER)"
              },
              "orientation": {
                "type": "string",
                "enum": ["HORIZONTAL_UP", "HORIZONTAL_DOWN", "VERTICAL"],
                "description": "Wärmeflussrichtung (nur bei AIR_LAYER)"
              },
              "r_value": { "type": "number", "description": "Wärmedurchlasswiderstand m²K/W (nur bei AIR_LAYER)" },
              "oekobau_uuid": { "type": "string", "description": "UUID aus Ökobaudat für LCA" }
            },
            "required": ["id", "name", "type"],
            "allOf": [
              {
                "if": { "properties": { "type": { "const": "STANDARD" } } },
                "then": { "required": ["lambda"] }
              },
              {
                "if": { "properties": { "type": { "const": "AIR_LAYER" } } },
                "then": { "required": ["air_layer_type", "orientation", "r_value"] }
              }
            ]
          }
        },
        "layer_structures": {
          "type": "array",
          "description": "Schichtaufbauten für opake Bauteile",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string", "description": "Eindeutige ID des Schichtaufbaus" },
              "name": { "type": "string", "description": "Bezeichnung (z.B. 'Außenwand WDVS 16cm')" },
              "type": {
                "type": "string",
                "enum": ["WALL", "ROOF", "FLOOR", "CEILING"],
                "description": "Bauteiltyp"
              },
              "layers": {
                "type": "array",
                "description": "Schichten von außen (Position 1) nach innen",
                "items": {
                  "type": "object",
                  "properties": {
                    "position": { "type": "integer", "minimum": 1, "description": "Schichtposition (1=außen)" },
                    "material_id": { "type": "string", "description": "Referenz auf materials[].id" },
                    "thickness_mm": { "type": "number", "description": "Schichtdicke in mm" }
                  },
                  "required": ["position", "material_id", "thickness_mm"]
                },
                "minItems": 1
              },
              "calculated_values": {
                "type": "object",
                "description": "Automatisch berechnete Kennwerte (optional)",
                "properties": {
                  "r_total_m2k_w": { "type": "number", "description": "Gesamtwärmewiderstand m²K/W" },
                  "u_value_w_m2k": { "type": "number", "description": "Berechneter U-Wert W/(m²K)" },
                  "sd_total_m": { "type": "number", "description": "Diffusionsäquivalente Luftschichtdicke m" },
                  "thermal_mass_j_m2k": { "type": "number", "description": "Wärmespeicherfähigkeit J/(m²K)" }
                }
              },
              "surface_properties": {
                "type": "object",
                "description": "Oberflächeneigenschaften",
                "properties": {
                  "exterior_finish": { "type": "string", "description": "Außenoberfläche (z.B. 'Putz weiß')" },
                  "solar_absorption": { "type": "number", "description": "Absorptionsgrad (0-1)" },
                  "emissivity": { "type": "number", "description": "Emissionsgrad (0-1)" }
                }
              }
            },
            "required": ["id", "name", "type", "layers"]
          }
        },
        "systems": {
          "description": "Wärmeerzeuger (Heizung)",
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "type": {
                "type": "string",
                "enum": ["BOILER_GAS", "BOILER_OIL", "BOILER_BIOMASS", "HEAT_PUMP_AIR", "HEAT_PUMP_BRINE", "HEAT_PUMP_WATER", "DISTRICT_HEATING", "DIRECT_ELECTRIC", "SOLAR_THERMAL", "PV"]
              },
              "energy_source": {
                "type": "string",
                "enum": ["GAS", "OIL", "ELECTRICITY", "WOOD", "DISTRICT"]
              },
              "name": { "type": "string" },
              "year_built": { "type": "integer" },
              "condensing": { "type": "boolean", "description": "Brennwerttechnik?" },
              "operation_mode": {
                "type": "string",
                "enum": ["MONOVALENT", "MONOENERGETIC", "BIVALENT_PARALLEL", "BIVALENT_ALTERNATIVE"]
              },
              "bivalence_temp": { "type": "number", "description": "Bivalenztemperatur in °C" },
              "heat_pump": {
                "type": "object",
                "properties": {
                  "cop_a2_w35": { "type": "number", "description": "COP A2/W35" },
                  "cop_a7_w35": { "type": "number", "description": "COP A7/W35" },
                  "refrigerant": { "type": "string", "description": "Kältemittel" }
                }
              }
            },
            "required": ["id", "type"]
          }
        },
        "distribution": {
          "description": "Wärmeverteilung",
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["TWO_PIPE", "ONE_PIPE", "TICHELMANN"]
              },
              "temp_flow_design": { "type": "number", "description": "Auslegungsvorlauftemperatur °C" },
              "temp_return_design": { "type": "number", "description": "Auslegungsrücklauftemperatur °C" },
              "pipe_insulation": {
                "type": "string",
                "enum": ["NONE", "100_PERCENT", "50_PERCENT", "ENEV"]
              },
              "hydraulic_balance": { "type": "boolean" },
              "pump_control": {
                "type": "string",
                "enum": ["UNCONTROLLED", "PRESSURE_CONTROLLED", "ADAPTIVE"]
              }
            }
          }
        },
        "dhw": {
          "description": "Trinkwarmwasser",
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["CENTRAL", "DECENTRAL_ELECTRIC", "DECENTRAL_GAS"]
              },
              "storage_volume": { "type": "number", "description": "Speichervolumen in Liter" },
              "storage_loss_factor": { "type": "number", "description": "Bereitschaftsverlust W/K" },
              "circulation": { "type": "boolean", "description": "Zirkulation vorhanden?" },
              "circulation_length": { "type": "number", "description": "Länge Zirkulationsleitung m" },
              "pipe_insulation": {
                "type": "string",
                "enum": ["NONE", "100_PERCENT", "ENEV"]
              }
            },
            "required": ["type"]
          }
        },
        "ventilation": {
          "description": "Lüftung",
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["WINDOW", "EXHAUST_ONLY", "SUPPLY_EXHAUST"]
              },
              "heat_recovery": { "type": "boolean" },
              "heat_recovery_efficiency": { "type": "number", "description": "Rückwärmezahl (0-1)" },
              "volume_flow": { "type": "number", "description": "Auslegungsvolumenstrom m³/h" },
              "spf_fan": { "type": "number", "description": "Spezifische Ventilatorleistung Wh/m³" }
            },
            "required": ["type"]
          }
        },
        "lighting": {
          "description": "Beleuchtung (DIN 18599-4)",
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "zone_id": { "type": "string" },
              "technology": {
                "type": "string",
                "enum": ["LED", "FLUORESCENT", "HALOGEN", "INCANDESCENT"]
              },
              "control": {
                "type": "string",
                "enum": ["MANUAL", "PRESENCE", "DAYLIGHT", "CONSTANT_LIGHT"]
              },
              "installed_power": { "type": "number", "description": "Installierte Leistung W/m²" }
            }
          }
        },
        "automation": {
          "description": "Gebäudeautomation (DIN 18599-11)",
          "type": "object",
          "properties": {
            "class": {
              "type": "string",
              "enum": ["A", "B", "C", "D"],
              "description": "Automationsklasse (A=High Performance, D=None)"
            }
          }
        },
        "pv": {
          "description": "Photovoltaik",
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "peak_power": { "type": "number", "description": "Nennleistung kWp" },
              "orientation": { "type": "number", "description": "Ausrichtung Grad" },
              "inclination": { "type": "number", "description": "Neigung Grad" },
              "system_loss": { "type": "number", "description": "Systemverluste (0-1)" },
              "battery_capacity": { "type": "number", "description": "Batteriespeicher kWh" }
            },
            "required": ["peak_power"]
          }
        }
      },
      "required": ["zones"]
    },
    "output": {
      "description": "Ergebnisse der Berechnung (Read-Only Snapshot)",
      "type": "object",
      "properties": {
        "energy_balance": {
          "type": "object",
          "properties": {
            "final_energy_kwh_a": { "type": "number", "description": "Endenergiebedarf" },
            "primary_energy_kwh_a": { "type": "number", "description": "Primärenergiebedarf" },
            "useful_energy_kwh_a": { "type": "number", "description": "Nutzenergiebedarf" },
            "energy_reference_area": { "type": "number", "description": "Energiebezugsfläche AN in m²" }
          }
        },
        "sectors": {
          "type": "object",
          "properties": {
            "heating_kwh_a": { "type": "number" },
            "cooling_kwh_a": { "type": "number" },
            "dhw_kwh_a": { "type": "number" },
            "ventilation_kwh_a": { "type": "number" },
            "lighting_kwh_a": { "type": "number" }
          }
        },
        "indicators": {
          "type": "object",
          "properties": {
            "qp_val_kwh_m2a": { "type": "number", "description": "Primärenergie Ist-Wert" },
            "qp_ref_kwh_m2a": { "type": "number", "description": "Primärenergie Anforderung" },
            "ht_prime_val_w_m2k": { "type": "number", "description": "Transmissionswärmeverlust Ist-Wert" },
            "ht_prime_ref_w_m2k": { "type": "number", "description": "Transmissionswärmeverlust Anforderung" },
            "efficiency_class": { "type": "string" },
            "co2_emissions_kg_a": { "type": "number" },
            "renewable_share_percent": { "type": "number" }
          }
        }
      }
    }
  }
