{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DIN 18599 Sidecar",
  "description": "JSON Sidecar für IFC-Dateien zur Abbildung von Energieberatungsdaten nach DIN 18599",
  "type": "object",
  "properties": {
    "schema": {
      "type": "string",
      "const": "https://din18599-ifc.de/schema/v1"
    },
    "schema_version": {
      "type": "string"
    },
    "din18599_norm_version": {
      "type": "string"
    },
    "metadata": {
      "type": "object",
      "properties": {
        "project_id": { "type": "string" },
        "ifc_file": { "type": "string" },
        "ifc_guid_building": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "created_by": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "software": { "type": "string" },
            "software_version": { "type": "string" }
          }
        }
      },
      "required": ["ifc_file", "ifc_guid_building"]
    },
    "gebaeude": {
      "type": "object",
      "properties": {
        "ifc_guid": { "type": "string" },
        "try_region": { "type": "integer" },
        "gebaeudetyp": { "type": "string" },
        "baujahr": { "type": "integer" }
      }
    },
    "zonen": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "ifc_guid_space": { "type": "string" },
          "bezeichnung": { "type": "string" },
          "nutzungsprofil": { "type": "string" },
          "zone_typ": { "type": "string", "enum": ["BEHEIZT", "UNBEHEIZT"] },
          "nrf": { "type": "number" },
          "raumhoehe": { "type": "number" },
          "temp_soll_heiz": { "type": "number" }
        },
        "required": ["id", "ifc_guid_space", "bezeichnung"]
      }
    },
    "bauteile": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "ifc_guid_element": { "type": "string" },
          "zone_id": { "type": "string" },
          "typ": { "type": "string", "enum": ["AW", "IW", "DA", "DE", "BO", "FE", "TU"] },
          "bezeichnung": { "type": "string" },
          "flaeche": { "type": "number" },
          "u_wert": { "type": "number" }
        },
        "required": ["id", "ifc_guid_element", "typ"]
      }
    },
    "anlagentechnik": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "typ": { "type": "string", "enum": ["HEIZUNG", "LUEFTUNG", "WW", "KUEHLUNG", "PV"] },
          "bezeichnung": { "type": "string" }
        },
        "required": ["id", "typ"]
      }
    },
    "varianten": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "bezeichnung": { "type": "string" },
          "typ": { "type": "string" },
          "massnahmen": { "type": "array", "items": { "type": "string" } },
          "bilanz": {
            "type": "object",
            "properties": {
              "qp_kwh_m2a": { "type": "number" },
              "effizienzklasse": { "type": "string" },
              "co2_kg_m2a": { "type": "number" }
            }
          }
        },
        "required": ["id", "bezeichnung"]
      }
    },
    "massnahmen": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "typ": { "type": "string" },
          "bezeichnung": { "type": "string" },
          "bauteil_ids": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["id", "typ", "bezeichnung"]
      }
    },
    "timeline": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "jahr": { "type": "integer" },
          "massnahme_ids": { "type": "array", "items": { "type": "string" } },
          "variante_id": { "type": "string" }
        }
      }
    }
  },
  "required": ["schema", "metadata", "gebaeude", "zonen", "bauteile"]
}
