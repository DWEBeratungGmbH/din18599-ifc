  "validation_rules": {
    "description": "Regeln zur Validierung von Symbol-Index-Kombinationen",
    "rules": [
      {
        "rule": "system_energy_level",
        "description": "Technisches Gewerk (L1) + Energieniveau (L2) ist valide",
        "valid_examples": ["Q_h,b", "Q_c,r", "Q_w,p"],
        "invalid_examples": ["Q_b,h"]
      },
      {
        "rule": "system_process_step",
        "description": "Technisches Gewerk (L1) + Prozessschritt (L2) ist valide",
        "valid_examples": ["Q_h,d", "Q_c,s", "Q_w,g"],
        "invalid_examples": ["Q_d,h"]
      },
      {
        "rule": "location_before_state",
        "description": "Ort (i/e) kommt vor Zustand (soll/ist)",
        "valid_examples": ["theta_i,h,soll", "theta_e"],
        "invalid_examples": ["theta_soll,i"]
      }
    ]
  },
  
  "common_patterns": {
    "description": "Häufig verwendete Symbol-Index-Muster",
    "patterns": [
      {
        "pattern": "Q_{system},b",
        "description": "Nutzenergiebedarf eines Gewerks",
        "examples": ["Q_h,b", "Q_c,b", "Q_w,b", "Q_l,b"]
      },
      {
        "pattern": "Q_{system},r",
        "description": "Endenergiebedarf eines Gewerks",
        "examples": ["Q_h,r", "Q_c,r", "Q_w,r", "Q_l,r"]
      },
      {
        "pattern": "Q_{system},{process}",
        "description": "Verluste/Aufwand in Prozessschritt",
        "examples": ["Q_h,d", "Q_h,s", "Q_h,g", "Q_w,ce"]
      },
      {
        "pattern": "theta_{location},{system},{state}",
        "description": "Temperatur mit Ort, Gewerk und Zustand",
        "examples": ["theta_i,h,soll", "theta_i,c,soll", "theta_e"]
      },
      {
        "pattern": "q_{source}[,{detail}]",
        "description": "Spezifische Wärmeleistung einer Quelle",
        "examples": ["q_I", "q_I,p", "q_I,app", "q_S"]
      }
    ]
  }
